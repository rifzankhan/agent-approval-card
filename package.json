{
  "name": "agent-approval-card",
  "version": "0.1.2",
  "description": "A polished React approval card for human-in-the-loop agent actions.",
  "author": "rifzan",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "homepage": "https://github.com/rifzankhan/agent-approval-card#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force dist, storybook-static, example/dist -ErrorAction SilentlyContinue\"",
    "pack:check": "pnpm pack",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "example": "vite --config example/vite.config.ts",
    "example:build": "vite build --config example/vite.config.ts"
  },
  "keywords": [
    "react",
    "ai",
    "agent",
    "approval",
    "approval-workflow",
    "copilot",
    "human-in-the-loop",
    "langgraph",
    "llm",
    "moderation",
    "component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rifzankhan/agent-approval-card.git"
  },
  "bugs": {
    "url": "https://github.com/rifzankhan/agent-approval-card/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.0.0",
    "storybook": "^8.6.14",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.7"
  }
}
